# === Supabase (cliente / público) ===
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx

# === Supabase (solo servidor: Netlify Functions / route handlers) ===
# NUNCA exponer con prefijo NEXT_PUBLIC_. Salta RLS: solo para arca_credenciales,
# webhooks de Mercado Pago y logs.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxx

# === ARCA / AFIP ===
# "production" usa los WSDL productivos de WSFE; "homologacion" usa los de testing
AFIP_MODE=homologacion

# CUIT y alias del certificado de la plataforma (los que los clientes
# autorizan en el Administrador de Relaciones de Clave Fiscal).
# Se muestran copiables en el wizard de onboarding.
NEXT_PUBLIC_PLATAFORMA_CUIT=30XXXXXXXXX
NEXT_PUBLIC_PLATAFORMA_ALIAS=factura-prod

# Certificado ÚNICO de la plataforma para el modo delegado (contenido PEM;
# en Netlify se pueden pegar con los saltos de línea como \n)
PLATAFORMA_AFIP_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
PLATAFORMA_AFIP_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# === Mercado Pago (OAuth de la aplicación de plataforma) ===
# Crear la app en https://www.mercadopago.com.ar/developers/panel/app
# Redirect URL a configurar en MP: {NEXT_PUBLIC_APP_URL}/api/mp/oauth/callback
# Webhook único a configurar en MP:  {NEXT_PUBLIC_APP_URL}/api/mp/webhook (evento "Pagos")
MP_CLIENT_ID=1234567890123456
MP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Clave secreta del webhook (panel de la app de MP → Webhooks → "Firma
# secreta"). Valida x-signature en los 3 webhooks de Mercado Pago. Si no se
# configura, los webhooks siguen funcionando (la mitigación principal —
# consultar el pago real contra la API de MP— sigue vigente) pero sin esta
# capa extra de verificación.
MP_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# === Mercado Pago (cuenta PROPIA de la plataforma, para cobrar suscripciones) ===
# Access token de PRODUCCIÓN de tu propia cuenta de Mercado Pago (Claudio),
# NO el de la app OAuth de arriba — este es el que le cobra a cada negocio
# su suscripción mensual a facturá.
# Webhook a configurar en esa cuenta: {NEXT_PUBLIC_APP_URL}/api/billing/webhook
# (evento "Suscripciones")
PLATAFORMA_MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxx

# === App ===
# URL pública del deploy (OAuth de MP y URLs de webhook)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Partner API (ecosistema soft-a-soft, ver PARTNERS.md) ===
# No requiere variables nuevas: las apps externas (ej: Soporte Móvil) se dan de
# alta como filas en la tabla `partner_apps` (client_id + hash del secret +
# redirect_uris + webhook). Reutiliza MP_CLIENT_ID/SECRET (cobros con la cuenta
# MP del negocio), SUPABASE_SERVICE_ROLE_KEY y NEXT_PUBLIC_APP_URL.
